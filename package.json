{
  "name": "lumen-ui-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "build:demo": "pnpm --filter ./apps/demo build",
    "dev": "pnpm --filter lumen-ui dev",
    "storybook": "pnpm --filter lumen-ui storybook",
    "build-storybook": "pnpm --filter lumen-ui build-storybook",
    "demo": "pnpm --filter ./apps/demo dev",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .next storybook-static"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
