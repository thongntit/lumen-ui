{
  "name": "lumen-ui",
  "version": "0.1.0",
  "description": "Lumen Design System — components for landing-page assembly. CWV-first.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/reset.css": "./dist/styles/reset.css",
    "./styles/typography.css": "./dist/styles/typography.css",
    "./styles/fonts.css": "./dist/styles/fonts.css",
    "./styles/index.css": "./dist/styles/index.css"
  },
  "scripts": {
    "build": "tsup && pnpm run build:styles && pnpm run build:directives",
    "build:styles": "node ./scripts/copy-styles.mjs",
    "build:directives": "node ./scripts/preserve-use-client.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^8.0.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
